#Admin Lock New Student
def ask_admin_password(action):
    win = tk.Toplevel(root)
    win.title("Admin Login")
    win.geometry("270x150")
    win.configure(bg="#008B8B")
    root.withdraw()

    (tk.Label(win, text="Enter Admin Password",bg="#008B8B", fg="white").
     pack(pady=5))
    entry_pass = tk.Entry(win, show="*", width=25, bg="light Blue")
    entry_pass.pack(pady=5)

    def verify():
        cursor.execute("SELECT password FROM admin WHERE id=1")
        correct_hash = cursor.fetchone()[0]
        entered_hash = hashlib.sha256(entry_pass.get().encode()).hexdigest()

        if entered_hash == correct_hash:
            win.destroy()
            action()
            root.withdraw()
        else:
            messagebox.showerror("Error",
                                 "Incorrect Admin Password")
            win.destroy()
            root.deiconify()

    tk.Button(win, text="Enter", command=verify, bg="#00FFFF").pack(pady=10)

