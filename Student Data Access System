import sqlite3
import hashlib

# Database setup
conn = sqlite3.connect("sda.db")
cursor = conn.cursor()

# Students table
cursor.execute("""
CREATE TABLE IF NOT EXISTS students 
(
    student_ID INTEGER PRIMARY KEY 
    CHECK(length(student_ID) <= 4),
    student_name TEXT NOT NULL 
    CHECK(length(student_name) <= 30)
);
""")

# Semester 1 table
cursor.execute("""
CREATE TABLE IF NOT EXISTS semester1 
(
    student_ID INTEGER PRIMARY KEY,
    CompTiA INTEGER 
    CHECK(CompTiA BETWEEN 0 AND 100), 
    C_Programming INTEGER 
    CHECK(C_Programming BETWEEN 0 AND 100), 
    Excel INTEGER 
    CHECK(Excel BETWEEN 0 AND 100), 
    Entrepreneurship INTEGER 
    CHECK(Entrepreneurship BETWEEN 0 AND 100),
    paid_amount1 REAL 
    CHECK(paid_amount1 >= 0),
    outstanding_amount1 REAL 
    CHECK(outstanding_amount1 >= 0),
    FOREIGN KEY(student_ID) 
    REFERENCES 
    students(student_ID) ON DELETE CASCADE
);
""")

# Semester 2 table
cursor.execute("""
CREATE TABLE IF NOT EXISTS semester2 
(
    student_ID INTEGER PRIMARY KEY,
    Python INTEGER 
    CHECK(Python BETWEEN 0 AND 100), 
    SQL INTEGER 
    CHECK(SQL BETWEEN 0 AND 100), 
    Data_Wrangling INTEGER 
    CHECK(Data_Wrangling BETWEEN 0 AND 100), 
    Data_Visualization INTEGER 
    CHECK(Data_Visualization BETWEEN 0 AND 100),
    paid_amount2 REAL 
    CHECK(paid_amount2 >= 0),
    outstanding_amount2 REAL 
    CHECK(outstanding_amount2 >= 0),
    FOREIGN KEY(student_ID) 
    REFERENCES 
    students(student_ID) ON DELETE CASCADE
);
""")

# Admin table
cursor.execute("""
CREATE TABLE IF NOT EXISTS admin (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    password TEXT NOT NULL
);
""")

cursor.execute("SELECT * FROM admin")
if cursor.fetchone() is None:
    default_password = hashlib.sha256("admin123".encode()).hexdigest()
    cursor.execute("INSERT INTO admin (password) VALUES (?)",
                   (default_password,))
    conn.commit()

